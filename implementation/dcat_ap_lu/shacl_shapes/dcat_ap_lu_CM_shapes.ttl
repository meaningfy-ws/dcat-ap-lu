        <http://www.w3.org/ns/dcat>,
        <http://www.w3.org/ns/locn>,
        odrl:,
        org:,
        <http://www.w3.org/ns/person>,
        prov:,
        foaf:,
        <https://data.europa.eu/m8g/>,
        core-res:core,
        core-res:core-restriction,
        <https://w3id.org/dpv#> ;
